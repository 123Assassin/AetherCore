POSTGRES_USER=aether
POSTGRES_PASSWORD=aether_secret
POSTGRES_DB=aether_db

REDIS_PASSWORD=redis_secret

WEB_PORT=3000
ADMIN_PORT=3001

# Local development URLs. docker-compose.yml overrides container runtime
# database/cache/API hosts to postgres, redis, and server on a private network.
DATABASE_URL=postgresql://aether:aether_secret@localhost:5432/aether_db
REDIS_URL=redis://:redis_secret@localhost:6379/0
SERVER_PORT=7001
APP_HTTP_URL=http://localhost:7001
WEB_HTTP_URL=http://localhost:3000
INTERNAL_API_URL=http://localhost:7001
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SIMULATION_APP_PORT=80
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

AETHERCORE_ENGINE_API_KEY_SECRET=aethercore_dev_engine_api_key_secret_change_me
WECHAT_APP_ID=replace_with_wechat_open_platform_app_id
WECHAT_APP_SECRET=replace_with_wechat_open_platform_app_secret
WECHAT_REDIRECT_URI=http://localhost:3000/auth/wechat/callback

ADMIN_USER=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
WEB_USER=teacher
WEB_USER_EMAIL=teacher@aethercore.local
WEB_USER_PASSWORD=teacher123
