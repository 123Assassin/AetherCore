{
  "name": "db-init",
  "private": true,
  "type": "module",
  "scripts": {
    "db:init": "dotenv -e ../../.env -- tsx src/index.ts",
    "db:seed": "dotenv -e ../../.env -- tsx src/index.ts --seed-only",
    "build": "tsc",
    "build:types": "tsc --emitDeclarationOnly",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@package/db": "workspace:*",
    "@package/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@package/eslint-config": "workspace:*",
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
