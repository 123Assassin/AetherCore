{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["apps/admin/src/*"],
      "@package/api": ["packages/api/src"],
      "@package/auth": ["packages/auth/src"],
      "@package/db": ["packages/db/src/index.ts"],
      "@package/db/schema": ["packages/db/src/schema/index.ts"],
      "@package/shared": ["packages/shared/src/index.ts"],
      "@package/ui": ["packages/ui/src"],
      "@package/*": ["packages/*/src"]
    }
  },
  "include": ["next-env.d.ts", "src", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
