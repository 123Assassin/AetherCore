{
  "name": "server",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "pnpm --dir ../.. --filter @package/db build && nest build",
    "dev": "pnpm --dir ../.. --filter @package/db build && dotenv -e ../../.env -- nest start --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "pnpm --dir ../.. --filter @package/db build && dotenv -e ../../.env -- node dist/main.js",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.1",
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-fastify": "^10.4.20",
    "@package/api": "workspace:*",
    "@package/auth": "workspace:*",
    "@package/db": "workspace:*",
    "@package/shared": "workspace:*",
    "@trpc/server": "^11.7.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@package/eslint-config": "workspace:*",
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3"
  }
}
