{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "noEmit": false,
    "paths": {
      "@/*": ["./src/*"],
      "@package/*": ["../../packages/*/src"]
    }
  },
  "include": ["src"]
}
